{
  "compilerOptions": {
    //Build dir
    "outDir": "./dist/",
    //linter
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    //
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "node", // Cambia 'node' por 'bundler' o 'node10'    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "ignoreDeprecations": "6.0", // Esto silenciará los avisos de 'deprecated' que mencionas
    "target": "ESNext",
    "typeRoots": [
      "node_modules/@types",
      "src/types"
    ],
    "types": [
      "webpack-env"
    ],
    "baseUrl": "./",
  },
  "include": [
    "src/*.ts",
    "src/**/*.ts"
, "src/project/scenes/Multiplayer/Backend/server.js"  ]
}